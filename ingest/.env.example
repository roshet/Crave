# Backend environment variables (FastAPI). Copy to .env for local dev, or set in the
# Render dashboard for production.

# Comma-separated list of allowed CORS origins. Defaults to localhost:5173-5175 if unset.
# In production this MUST be the exact frontend URL — if it's wrong, the browser blocks
# every API call with a CORS error and the UI silently shows no data.
CORS_ORIGINS=https://fast-food-ui.vercel.app
